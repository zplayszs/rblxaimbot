-- =====================
--   SKELETON FUNCTIONS
-- =====================
-- R6 uses 13 faked lines to mimic R15 look (elbow/knee midpoints calculated)
local MAX_BONES = math.max(#BONES_R15, 13)
local function GetSkeleton(player)
    if not SkeletonObjects[player] then
        SkeletonObjects[player] = {}
        for i = 1, MAX_BONES do
            local line = Drawing.new("Line")
            line.Visible = false
            line.Color = Settings.ESP.Color
            line.Thickness = 1.5
            SkeletonObjects[player][i] = line
        end
    end
    return SkeletonObjects[player]
end

local function RemoveSkeleton(player)
    if SkeletonObjects[player] then
        for _, line in pairs(SkeletonObjects[player]) do
            line:Remove()
        end
        SkeletonObjects[player] = nil
    end
end

-- Helper: world pos -> screen Vec2, returns nil if off screen
local function W2S(pos)
    local s, vis = Camera:WorldToViewportPoint(pos)
    if not vis or s.Z <= 0 then return nil end
    return Vector2.new(s.X, s.Y)
end

-- Draw a line between two world positions, hide if either is off screen
local function DrawBoneLine(line, posA, posB)
    local sA = W2S(posA)
    local sB = W2S(posB)
    if not sA or not sB then
        line.Visible = false
        return
    end
    line.From    = sA
    line.To      = sB
    line.Color   = Settings.ESP.Color
    line.Visible = true
end

local function UpdateSkeleton()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local lines = GetSkeleton(player)
        local char  = player.Character

        if not Settings.ESP.SkeletonEnabled or not char then
            for _, l in pairs(lines) do l.Visible = false end
            continue
        end

        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then
            for _, l in pairs(lines) do l.Visible = false end
            continue
        end

        if IsR6(char) then
            -- R6 parts
            local head  = char:FindFirstChild("Head")
            local torso = char:FindFirstChild("Torso")
            local lArm  = char:FindFirstChild("Left Arm")
            local rArm  = char:FindFirstChild("Right Arm")
            local lLeg  = char:FindFirstChild("Left Leg")
            local rLeg  = char:FindFirstChild("Right Leg")

            if not (head and torso and lArm and rArm and lLeg and rLeg) then
                for _, l in pairs(lines) do l.Visible = false end
                continue
            end

            -- Use CFrame to correctly offset points relative to character rotation
            local cf = torso.CFrame

            -- Spine points relative to torso CFrame
            local torsoTop    = (cf * CFrame.new(0,  1, 0)).Position
            local torsoBottom = (cf * CFrame.new(0, -1, 0)).Position

            -- Shoulders: sides of torso top, rotated with character
            local lShoulder = (cf * CFrame.new(-1.5, 1, 0)).Position
            local rShoulder = (cf * CFrame.new( 1.5, 1, 0)).Position

            -- Arm bottoms: use arm CFrame so they rotate correctly too
            local lArmBottom = (lArm.CFrame * CFrame.new(0, -1, 0)).Position
            local rArmBottom = (rArm.CFrame * CFrame.new(0, -1, 0)).Position

            -- Leg bottoms: use leg CFrame
            local lLegBottom = (lLeg.CFrame * CFrame.new(0, -1, 0)).Position
            local rLegBottom = (rLeg.CFrame * CFrame.new(0, -1, 0)).Position

            DrawBoneLine(lines[1], head.Position, torsoTop)      -- neck
            DrawBoneLine(lines[2], torsoTop,      torsoBottom)   -- spine
            DrawBoneLine(lines[3], lShoulder,     rShoulder)     -- shoulder bar
            DrawBoneLine(lines[4], lShoulder,     lArmBottom)    -- left arm
            DrawBoneLine(lines[5], rShoulder,     rArmBottom)    -- right arm
            DrawBoneLine(lines[6], torsoBottom,   lLegBottom)    -- left leg
            DrawBoneLine(lines[7], torsoBottom,   rLegBottom)    -- right leg
            for i = 8, MAX_BONES do lines[i].Visible = false end

        else
            -- R15: use actual parts
            local rigBones = BONES_R15
            for i = #rigBones + 1, MAX_BONES do lines[i].Visible = false end
            for i, bone in ipairs(rigBones) do
                local pA = char:FindFirstChild(bone[1])
                local pB = char:FindFirstChild(bone[2])
                if pA and pB then
                    DrawBoneLine(lines[i], pA.Position, pB.Position)
                else
                    lines[i].Visible = false
                end
            end
        end
    end
end

