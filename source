-- =====================
--   ESP FUNCTIONS
-- =====================
local function GetESP(player)
    if not ESPObjects[player] then
        ESPObjects[player] = {
            Top    = Drawing.new("Line"),
            Bottom = Drawing.new("Line"),
            Left   = Drawing.new("Line"),
            Right  = Drawing.new("Line"),
            Label  = Drawing.new("Text"),
        }
        for _, d in pairs(ESPObjects[player]) do
            d.Visible = false
            if d.Color ~= nil then d.Color = Settings.ESP.Color end
            if d.Thickness ~= nil then d.Thickness = Settings.ESP.BoxThickness end
        end
        local lbl = ESPObjects[player].Label
        lbl.Size = 13
        lbl.Font = 2
        lbl.Color = Color3.fromRGB(255, 255, 255)
        lbl.Outline = true
    end
    return ESPObjects[player]
end

local function RemoveESP(player)
    if ESPObjects[player] then
        for _, d in pairs(ESPObjects[player]) do
            d:Remove()
        end
        ESPObjects[player] = nil
    end
end

local function UpdateESP()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local esp = GetESP(player)
        local char = player.Character
        local rootPart = char and char:FindFirstChild("HumanoidRootPart")
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")

        if not Settings.ESP.Enabled or not rootPart or not humanoid or humanoid.Health <= 0 then
            for _, d in pairs(esp) do d.Visible = false end
            continue
        end

        -- World bounding box approximation
        local hrpPos = rootPart.Position
        local _, onScreen = Camera:WorldToViewportPoint(hrpPos)
        if not onScreen then
            for _, d in pairs(esp) do d.Visible = false end
            continue
        end

        local head = char:FindFirstChild("Head")
        local headPos = head and head.Position or (hrpPos + Vector3.new(0, 2.5, 0))
        local feetPos = hrpPos - Vector3.new(0, 3, 0)

        local topScreen, topVis   = Camera:WorldToViewportPoint(headPos + Vector3.new(0, 0.5, 0))
        local botScreen, botVis   = Camera:WorldToViewportPoint(feetPos)
        local leftScreen          = Camera:WorldToViewportPoint(hrpPos + Vector3.new(-1, 0, 0))
        local rightScreen         = Camera:WorldToViewportPoint(hrpPos + Vector3.new(1, 0, 0))

        if not topVis then
            for _, d in pairs(esp) do d.Visible = false end
            continue
        end

        local top    = Vector2.new(topScreen.X, topScreen.Y)
        local bot    = Vector2.new(botScreen.X, botScreen.Y)
        local height = math.abs(top.Y - bot.Y)
        local width  = height * 0.55

        local tl = Vector2.new(top.X - width / 2, top.Y)
        local tr = Vector2.new(top.X + width / 2, top.Y)
        local bl = Vector2.new(bot.X - width / 2, bot.Y)
        local br = Vector2.new(bot.X + width / 2, bot.Y)

        -- Draw 4 lines for box
        local lines = esp
        lines.Top.From    = tl ; lines.Top.To    = tr ; lines.Top.Visible    = true ; lines.Top.Color = Settings.ESP.Color
        lines.Bottom.From = bl ; lines.Bottom.To = br ; lines.Bottom.Visible = true ; lines.Bottom.Color = Settings.ESP.Color
        lines.Left.From   = tl ; lines.Left.To   = bl ; lines.Left.Visible   = true ; lines.Left.Color = Settings.ESP.Color
        lines.Right.From  = tr ; lines.Right.To  = br ; lines.Right.Visible  = true ; lines.Right.Color = Settings.ESP.Color

        -- Distance label
        local dist = math.floor((Camera.CFrame.Position - hrpPos).Magnitude / 3.281) -- convert studs to ~meters
        lines.Label.Text     = player.Name .. " [" .. dist .. "m]"
        lines.Label.Position = Vector2.new(tl.X, tl.Y - 16)
        lines.Label.Visible  = true
    end
end

-- =====================
--   AIMBOT FUNCTIONS
-- =====================
local function GetClosestInFOV()
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local closest, closestDist = nil, math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local char = player.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end

        local aimPart = char:FindFirstChild(Settings.Aimbot.AimPart) or hrp
        local screenPos, onScreen = Camera:WorldToViewportPoint(aimPart.Position)
        if not onScreen then continue end

        local screen2D = Vector2.new(screenPos.X, screenPos.Y)
        local dist2D = (screen2D - center).Magnitude

        if dist2D <= Settings.FOV.Radius and dist2D < closestDist then
            closestDist = dist2D
            closest = player
        end
    end
    return closest
end

local function AimbotStep()
    if not Settings.Aimbot.Enabled then return end
    if not UserInputService:IsMouseButtonPressed(Settings.Aimbot.Key) then return end

    local target = GetClosestInFOV()
    if not target then return end

    local char = target.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    -- Pick head or torso as the aim point
    local aimPart = char:FindFirstChild(Settings.Aimbot.AimPart) or hrp

    -- Apply prediction using velocity
    local velocity = hrp.AssemblyLinearVelocity
    local predicted = aimPart.Position + velocity * Settings.Aimbot.Prediction

    local targetCF = CFrame.lookAt(Camera.CFrame.Position, predicted)
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, Settings.Aimbot.Smoothness)
end

