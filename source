--   MAIN LOOP
-- =====================
local ESPUpdateCounter = 0
local ESPUpdateInterval = 2 -- Update ESP every 2 frames (~30ms at 60 FPS)

table.insert(AllConnections, RunService.RenderStepped:Connect(function()
    -- Update FOV circle every frame
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    FOVCircle.Visible  = Settings.FOV.Enabled
    FOVCircle.Radius   = Settings.FOV.Radius
    FOVCircle.Color    = Settings.FOV.Color

    -- Update ESP and skeleton less frequently to reduce CPU
    ESPUpdateCounter = (ESPUpdateCounter + 1) % ESPUpdateInterval
    if ESPUpdateCounter == 0 then
        UpdateESP()
        UpdateSkeleton()
    end
    
    -- Aimbot at normal priority (same as ESP)
    AimbotStep()
end))
