-- =====================
--   SKELETON FUNCTIONS
-- =====================
local function GetSkeleton(player)
    if not SkeletonObjects[player] then
        SkeletonObjects[player] = {}
        for i = 1, MAX_BONES do
            local line = Drawing.new("Line")
            line.Visible = false
            line.Color = Settings.ESP.Color
            line.Thickness = 1.5
            SkeletonObjects[player][i] = line
        end
    end
    return SkeletonObjects[player]
end

local function RemoveSkeleton(player)
    if SkeletonObjects[player] then
        for _, line in pairs(SkeletonObjects[player]) do line:Remove() end
        SkeletonObjects[player] = nil
    end
end

local function OnCharacterRespawn(player)
    RemoveSkeleton(player)
end

local function W2S(pos)
    local s, vis = Camera:WorldToViewportPoint(pos)
    if not vis or s.Z <= 0 then return nil end
    return Vector2.new(s.X, s.Y)
end

local function DrawBoneLine(line, posA, posB)
    local sA = W2S(posA)
    local sB = W2S(posB)
    if not sA or not sB then line.Visible = false; return end
    line.From = sA
    line.To = sB
    line.Color = Settings.ESP.Color
    line.Visible = true
end

local function UpdateSkeleton()
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local lines = GetSkeleton(player)
        local char = player.Character

        if not Settings.ESP.SkeletonEnabled or not char then
            for _, l in pairs(lines) do l.Visible = false end
            continue
        end

        local humanoid = char:FindFirstChildOfClass("Humanoid")
        if not humanoid or humanoid.Health <= 0 then
            for _, l in pairs(lines) do l.Visible = false end
            continue
        end

        if IsR6(char) then
            local head  = char:FindFirstChild("Head")
            local torso = char:FindFirstChild("Torso")
            local lArm  = char:FindFirstChild("Left Arm")
            local rArm  = char:FindFirstChild("Right Arm")
            local lLeg  = char:FindFirstChild("Left Leg")
            local rLeg  = char:FindFirstChild("Right Leg")

            if not (head and torso and lArm and rArm and lLeg and rLeg) then
                for _, l in pairs(lines) do l.Visible = false end
                continue
            end

            -- Use actual part positions - these are consistent world-space points
            local headPos    = head.Position
            local torsoPos   = torso.Position
            local lArmPos    = lArm.Position
            local rArmPos    = rArm.Position
            local lLegPos    = lLeg.Position
            local rLegPos    = rLeg.Position

            -- Simple stick figure: head to torso, arms from torso, legs from torso
            DrawBoneLine(lines[1], headPos,    torsoPos)   -- neck
            DrawBoneLine(lines[2], lArmPos,    rArmPos)    -- shoulder bar
            DrawBoneLine(lines[3], torsoPos,   lArmPos)    -- left arm
            DrawBoneLine(lines[4], torsoPos,   rArmPos)    -- right arm
            DrawBoneLine(lines[5], torsoPos,   lLegPos)    -- left leg
            DrawBoneLine(lines[6], torsoPos,   rLegPos)    -- right leg
            for i = 7, MAX_BONES do lines[i].Visible = false end
        else
            for i = #BONES_R15 + 1, MAX_BONES do lines[i].Visible = false end
            for i, bone in ipairs(BONES_R15) do
                local pA = char:FindFirstChild(bone[1])
                local pB = char:FindFirstChild(bone[2])
                if pA and pB then
                    DrawBoneLine(lines[i], pA.Position, pB.Position)
                else
                    lines[i].Visible = false
                end
            end
        end
    end
end

-- =====================
--   ESP FUNCTIONS
-- =====================
local function GetESP(player)
    if not ESPObjects[player] then
        ESPObjects[player] = {
            Top    = Drawing.new("Line"),
            Bottom = Drawing.new("Line"),
            Left   = Drawing.new("Line"),
            Right  = Drawing.new("Line"),
            Label  = Drawing.new("Text"),
        }
        for _, d in pairs(ESPObjects[player]) do
            d.Visible = false
            if d.Color ~= nil then d.Color = Settings.ESP.Color end
            if d.Thickness ~= nil then d.Thickness = Settings.ESP.BoxThickness end
        end
        local lbl = ESPObjects[player].Label
        lbl.Size = 13
        lbl.Font = 2
        lbl.Color = Color3.fromRGB(255, 255, 255)
        lbl.Outline = true
    end
    return ESPObjects[player]
end

local function RemoveESP(player)
    if ESPObjects[player] then
        for _, d in pairs(ESPObjects[player]) do d:Remove() end
        ESPObjects[player] = nil
    end
    RemoveSkeleton(player)
end

local LastESPColor = Settings.ESP.Color

local function UpdateESP()
    -- Only update color line if it actually changed
    local colorChanged = LastESPColor ~= Settings.ESP.Color
    if colorChanged then LastESPColor = Settings.ESP.Color end

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        local esp = GetESP(player)
        local char = player.Character
        local rootPart = char and char:FindFirstChild("HumanoidRootPart")
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")

        if not Settings.ESP.Enabled or not rootPart or not humanoid or humanoid.Health <= 0 then
            for _, d in pairs(esp) do d.Visible = false end
            continue
        end

        local hrpPos = rootPart.Position
        local _, onScreen = Camera:WorldToViewportPoint(hrpPos)
        if not onScreen then
            for _, d in pairs(esp) do d.Visible = false end
            continue
        end

        local head = char:FindFirstChild("Head")
        local headPos = head and head.Position or (hrpPos + Vector3.new(0, 2.5, 0))
        local feetPos = hrpPos - Vector3.new(0, 3, 0)

        local topScreen, topVis = Camera:WorldToViewportPoint(headPos + Vector3.new(0, 0.5, 0))
        local botScreen         = Camera:WorldToViewportPoint(feetPos)

        if not topVis then
            for _, d in pairs(esp) do d.Visible = false end
            continue
        end

        local top    = Vector2.new(topScreen.X, topScreen.Y)
        local bot    = Vector2.new(botScreen.X, botScreen.Y)
        local height = math.abs(top.Y - bot.Y)
        
        -- Calculate consistent world-space width using character size
        local success, cf, boundSize = pcall(function()
            return char:GetBoundingBox()
        end)
        
        local worldWidth = 2.0  -- default width
        if success and cf and boundSize then
            worldWidth = math.max(boundSize.X, boundSize.Z) * 1.1
        else
            -- Fallback: use rootPart size
            worldWidth = (rootPart.Size.X + rootPart.Size.Z) / 2
        end
        
        -- Project world width to screen at the target's position
        -- Use the TOP of the character for more accurate projection
        local headWorldPos = rootPart.Position + Vector3.new(0, 3, 0)
        local headScreen = Camera:WorldToViewportPoint(headWorldPos)
        
        local leftWorldPos = headWorldPos - Vector3.new(worldWidth / 2, 0, 0)
        local rightWorldPos = headWorldPos + Vector3.new(worldWidth / 2, 0, 0)
        
        local leftScreen = Camera:WorldToViewportPoint(leftWorldPos)
        local rightScreen = Camera:WorldToViewportPoint(rightWorldPos)
        
        local width = math.abs(rightScreen.X - leftScreen.X)
        width = math.max(width, height * 0.3)

        local tl = Vector2.new(top.X - width / 2, top.Y)
        local tr = Vector2.new(top.X + width / 2, top.Y)
        local bl = Vector2.new(bot.X - width / 2, bot.Y)
        local br = Vector2.new(bot.X + width / 2, bot.Y)

        -- Only update color if it changed
        if colorChanged then
            esp.Top.Color    = Settings.ESP.Color
            esp.Bottom.Color = Settings.ESP.Color
            esp.Left.Color   = Settings.ESP.Color
            esp.Right.Color  = Settings.ESP.Color
        end

        esp.Top.From    = tl; esp.Top.To    = tr; esp.Top.Visible    = true
        esp.Bottom.From = bl; esp.Bottom.To = br; esp.Bottom.Visible = true
        esp.Left.From   = tl; esp.Left.To   = bl; esp.Left.Visible   = true
        esp.Right.From  = tr; esp.Right.To  = br; esp.Right.Visible  = true

        local dist = math.floor((Camera.CFrame.Position - hrpPos).Magnitude / 3.281)
        esp.Label.Text     = player.Name .. " [" .. dist .. "m]"
        esp.Label.Position = Vector2.new(tl.X, tl.Y - 16)
        esp.Label.Visible  = true
    end
end

-- =====================
--   AIMBOT FUNCTIONS
-- =====================
-- Cache resolver offsets to avoid table recreation
local RESOLVER_OFFSETS = {0, 90, -90, 180, 45, -45, 135, -135}

-- Track last target check time for optimization
local LastTarget = nil
local LastTargetCheckFrame = 0

-- Cache raycast ignore list and params
local RayParams = RaycastParams.new()
RayParams.FilterType = Enum.RaycastFilterType.Exclude
local CurrentIgnoreList = {}

local function BuildWallCheckIgnoreList(targetChar)
    table.clear(CurrentIgnoreList)
    if LocalPlayer.Character then
        table.insert(CurrentIgnoreList, LocalPlayer.Character)
    end
    if targetChar then
        table.insert(CurrentIgnoreList, targetChar)
    end
    RayParams.FilterDescendantsInstances = CurrentIgnoreList
end

-- Build ignore list once at startup
-- (We'll use the simplified BuildWallCheckIgnoreList for wall checks instead)

-- Simple resolver frame counter (no yields inside render)
local ResolverFrameCounter = 0
local RESOLVER_CHANGE_INTERVAL = 10 -- Change offset every 10 frames

local function GetClosestInFOV()
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local closest, closestDist = nil, math.huge

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Parent then continue end
        
        local char = player.Character
        if not char then continue end

        local hrp = char:FindFirstChild("HumanoidRootPart")
            or char:FindFirstChild("Torso")
            or char:FindFirstChildWhichIsA("BasePart")
        if not hrp then continue end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end

        local aimPart = char:FindFirstChild(Settings.Aimbot.AimPart) or hrp
        if not aimPart then continue end

        local screenPos, onScreen = Camera:WorldToViewportPoint(aimPart.Position)
        if not onScreen or screenPos.Z <= 0 then continue end

        if Settings.Aimbot.TeamCheck then
            if LocalPlayer.Team ~= nil and player.Team == LocalPlayer.Team then continue end
        end

        if Settings.Aimbot.WallCheck then
            local origin    = Camera.CFrame.Position
            local direction = aimPart.Position - origin
            local distance  = direction.Magnitude

            if distance > 0 then
                BuildWallCheckIgnoreList(char)
                local result = workspace:Raycast(origin, direction.Unit * distance, RayParams)
                if result and result.Instance then continue end
            end
        end

        local screen2D = Vector2.new(screenPos.X, screenPos.Y)
        local dist2D   = (screen2D - center).Magnitude
        if dist2D <= Settings.FOV.Radius and dist2D < closestDist then
            closestDist = dist2D
            closest = player
        end
    end
    return closest
end

local function AimbotStep()
    if not Settings.Aimbot.Enabled then return end

    local keyDown = UserInputService:IsMouseButtonPressed(Settings.Aimbot.Key)

    -- On key release, clear aim lock
    if not keyDown then
        if Settings.Aimbot.AimLock and AimKeyHeld then
            AimLockTarget = nil
        end
        AimKeyHeld = false
        return
    end
    AimKeyHeld = true

    local target

    if Settings.Aimbot.AimLock then
        -- Validate existing lock
        if AimLockTarget then
            -- Check parent first (player still in game)
            if not AimLockTarget.Parent then
                AimLockTarget = nil
            else
                local lockChar = AimLockTarget.Character
                local lockHum  = lockChar and lockChar:FindFirstChildOfClass("Humanoid")
                if not lockChar or not lockHum or lockHum.Health <= 0 then
                    AimLockTarget = nil
                end
            end
        end
        if not AimLockTarget then
            AimLockTarget = GetClosestInFOV()
        end
        target = AimLockTarget
    else
        AimLockTarget = nil
        -- Optimize: only find new target every few frames to reduce CPU
        LastTargetCheckFrame = (LastTargetCheckFrame or 0) + 1
        if LastTargetCheckFrame >= 3 then -- Check every 3 frames (~50ms at 60 FPS)
            LastTarget = GetClosestInFOV()
            LastTargetCheckFrame = 0
        end
        target = LastTarget
    end

    if not target or not target.Parent then return end

    local char = target.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local aimPart = char:FindFirstChild(Settings.Aimbot.AimPart) or hrp
    if not aimPart then return end
    
    local velocity  = hrp.AssemblyLinearVelocity
    local predicted = aimPart.Position + velocity * Settings.Aimbot.Prediction

    -- Resolver: Try different yaw offsets to hit through anti-aim
    -- Advance offset every N frames without yielding
    ResolverFrameCounter = (ResolverFrameCounter + 1) % RESOLVER_CHANGE_INTERVAL
    if ResolverFrameCounter == 0 then
        Settings.Aimbot.ResolverOffset = (Settings.Aimbot.ResolverOffset % #RESOLVER_OFFSETS) + 1
    end
    local yawDeg = RESOLVER_OFFSETS[Settings.Aimbot.ResolverOffset]

    if yawDeg ~= 0 then
        local originPos = hrp.Position
        local rad       = math.rad(yawDeg)
        local cos_r     = math.cos(rad)
        local sin_r     = math.sin(rad)
        local dx        = predicted.X - originPos.X
        local dz        = predicted.Z - originPos.Z
        predicted = Vector3.new(
            originPos.X + dx * cos_r - dz * sin_r,
            predicted.Y,
            originPos.Z + dx * sin_r + dz * cos_r
        )
    end

    -- Smooth camera rotation using angle lerp (avoids camera fighting with game controller)
    local camPos   = Camera.CFrame.Position
    local toTarget = (predicted - camPos)
    
    -- Only aim if target is in front of camera (prevent backwards aiming)
    if toTarget.Magnitude < 0.1 then return end
    
    local toTargetUnit = toTarget.Unit
    local yaw   = math.atan2(-toTargetUnit.X, -toTargetUnit.Z)
    local pitch = math.asin(math.clamp(toTargetUnit.Y, -1, 1))

    local curLook  = Camera.CFrame.LookVector
    local curYaw   = math.atan2(-curLook.X, -curLook.Z)
    local curPitch = math.asin(math.clamp(curLook.Y, -1, 1))

    -- Smooth angle lerp with proper wrap-around
    local function lerpAngle(a, b, t)
        local diff = ((b - a + math.pi) % (2 * math.pi)) - math.pi
        return a + diff * t
    end

    local s = Settings.Aimbot.Smoothness
    local newYaw   = lerpAngle(curYaw, yaw, s)
    local newPitch = math.clamp(lerpAngle(curPitch, pitch, s), -math.pi / 2.5, math.pi / 2.5)

    -- Build camera CFrame from angles (keeps position intact)
    local newCFrame = CFrame.new(camPos) * CFrame.Angles(0, newYaw, 0) * CFrame.Angles(newPitch, 0, 0)
    
    -- Set camera directly without mode switching to avoid flickering
    Camera.CFrame = newCFrame
end

